<?xml version="1.0" encoding="utf-8"?>
<Project>
  <Target Name="LoadIlasm">
    <Exec Command="command -v ilasm"
          ConsoleToMSBuild="true"
          IgnoreExitCode="true"
          IgnoreStandardErrorWarningFormat="true">
      <Output TaskParameter="ConsoleOutput" ItemName="_SystemIlasm" />
    </Exec>
    <Error Condition="'@(_SystemIlasm)' == ''"
           Text="ILAsm is required on macOS. Install it with 'brew install mono'." />
    <PropertyGroup>
      <_IlasmExecutable>@(_SystemIlasm)</_IlasmExecutable>
    </PropertyGroup>
  </Target>

  <!-- The Csc tasks in DLR bypass the project's LangVersion property. -->
  <Target Name="ReachType" Inputs="@(ReachTypeInput)" Outputs="@(ReachTypeOutput)" DependsOnTargets="LoadIlasm">
    <Csc LangVersion="$(LangVersion)" TargetType="Library" References="@(ReferencePath)" Sources="Src\loadtypesample.cs" OutputAssembly="$(OutputPath)\$(Prefix)loadtypesample.dll" />
    <Csc LangVersion="$(LangVersion)" TargetType="Library" References="@(ReferencePath)" Sources="Src\missingtype.cs" OutputAssembly="$(OutputPath)\$(Prefix)missingtype.dll" />
    <Csc LangVersion="$(LangVersion)" TargetType="Library" References="@(ReferencePath);$(OutputPath)\$(Prefix)missingtype.dll" Sources="Src\loadexception.cs" OutputAssembly="$(OutputPath)\$(Prefix)loadexception.dll" />
    <Delete Files="$(OutputPath)\$(Prefix)missingtype.dll" />
    <Csc LangVersion="$(LangVersion)" TargetType="Library" References="@(ReferencePath)" Sources="Src\typeforwardee1.cs" OutputAssembly="$(OutputPath)\$(Prefix)typeforwardee1.dll" />
    <Csc LangVersion="$(LangVersion)" TargetType="Library" References="@(ReferencePath);$(OutputPath)\$(Prefix)typeforwardee1.dll" Sources="Src\typeforwarder1.cs" OutputAssembly="$(OutputPath)\$(Prefix)typeforwarder1.dll" />
    <Csc LangVersion="$(LangVersion)" TargetType="Library" References="@(ReferencePath)" Sources="Src\typeforwardee2.cs" OutputAssembly="$(OutputPath)\$(Prefix)typeforwardee2.dll" />
    <Exec Command="&quot;$(_IlasmExecutable)&quot; -NOLOGO -QUIET -DLL -OUTPUT=&quot;$(OutputPath)/$(Prefix)typeforwarder2.dll&quot; Src/typeforwarder2.il" />
    <Csc LangVersion="$(LangVersion)" TargetType="Library" References="@(ReferencePath)" Sources="Src\typeforwardee3.cs" OutputAssembly="$(OutputPath)\$(Prefix)typeforwardee3.dll" />
    <Csc LangVersion="$(LangVersion)" TargetType="Library" References="@(ReferencePath);$(OutputPath)\$(Prefix)typeforwardee3.dll" Sources="Src\typeforwarder3.cs" OutputAssembly="$(OutputPath)\$(Prefix)typeforwarder3.dll" />
  </Target>
</Project>
